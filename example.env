# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Zoho Payments Configuration
# Get these from Zoho API Console (https://api-console.zoho.in/)
ZOHO_CLIENT_ID=your_client_id
ZOHO_CLIENT_SECRET=your_client_secret
ZOHO_REFRESH_TOKEN=your_refresh_token # Also known as "Regenerated API Key"

# Zoho Payments Settings Support
# Get these from Zoho Payments > Settings > Developer Space
ZOHO_ORGANIZATION_ID=your_org_id (also used as ZOHO_USER_ID)
VITE_ZOHO_PAYMENTS_DOMAIN=IN # For zoho.in (use US, EU, AU etc as needed)

# Webhook Security
# Get this from Zoho Payments > Settings > Webhooks
ZOHO_PAYMENTS_WEBHOOK_SECRET=your_webhook_secret # Also known as "Signing in Key"

# Optional Static API Key (if using legacy API methods)
VITE_ZOHO_PAYMENTS_API_KEY=your_static_api_key
VITE_ZOHO_PAYMENTS_ACCOUNT_ID=your_account_id
